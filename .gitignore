# env files — never commit secrets
.env
.env.local
.env.bak.*
.env.bak

# node
node_modules/
dist/
*.log
.npm/
.pnpm-store/

# rust
target/
**/*.rs.bk
Cargo.lock

# macOS
.DS_Store
._*

# editors
.idea/
.vscode/

# Claude Code local settings (gitignore everything EXCEPT shared skills)
.claude/*
!.claude/skills/
!.claude/skills/**

# Blindfold runtime telemetry (per-machine; not for the repo)
.blindfold/

# test / coverage
coverage/
.nyc_output/

# T3 dev-team correspondence / working notes (local only)
response.md
.gstack/

# Generated compatibility / status reports (may embed env key names)
report.html

# OpenCode skill install (per-machine copy; source is .claude/skills)
.opencode/
