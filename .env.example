# ─── Terminal 3 (required for Blindfold to talk to the enclave) ──────────────
# This is your secp256k1 (Ethereum-format) private key. The SDK signs auth
# challenges with it. Treat it like any other root credential.
T3N_API_KEY=0x...

# Your tenant DID, derived from the key above. Format: did:t3n:<id>
DID=did:t3n:...

# ─── The secret you want to protect (REQUIRED ONLY DURING ONE-TIME REGISTRATION) ─
# Set this just long enough to run `blindfold register`, then delete it.
# After registration, this key lives only inside the T3 TDX enclave.
# OPENAI_API_KEY=sk-...

# ─── Blindfold runtime ───────────────────────────────────────────────────────
# Port for the local OpenAI-shaped proxy.
BLINDFOLD_PORT=8787

# Which environment to target on T3 ("testnet" or "production").
BLINDFOLD_T3_ENV=testnet
