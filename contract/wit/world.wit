// Blindfold proxy contract.
//
// The host WIT packages under wit/deps/ are now T3's CANONICAL signatures,
// provided verbatim by the T3 dev team (see wit/deps/README.md and the
// repo-root response.md). This supersedes the earlier workaround:
//
// The earlier best-effort http stub declared a `response` record WITH
// headers. T3's running host links a `response` that is `{ code: u16,
// payload: list<u8> }` only — no response headers. That signature mismatch
// is what caused the contract to fail at instantiation when http was
// imported (HTTP 500 with no typed body). With the canonical signatures
// vendored, `host:interfaces/http@2.1.0` now imports cleanly.
//
// Runtime note from T3: tenant HTTP egress is gated by the caller's
// agent_auth grant — http.call returns Err unless the target host is
// authorised for that user (grant wiring: scripts/grant-and-call.ts and
// scripts/grant-egress.ts). Build + register succeeding does NOT mean an
// arbitrary host is reachable; that is an authorisation outcome, not a stub
// bug.
//
// Pin @2.1.0 — that's what the live host links. A @2.2.0 label may appear on
// the canonical file flagging newer additive interfaces; interfaces are
// additive, so a @2.1.0 import resolves against the running host fine.
//
// `forward.rs` currently performs the in-enclave header substitution and
// returns a dry-run proof; `release-to-tenant` is the live path. Wiring
// `forward` to actually invoke http.call (returning response.code /
// response.payload) is now unblocked by the http import above and only
// needs the egress grant in place.
package z:blindfold@0.1.0;

world blindfold-proxy {
  import host:tenant/tenant-context@1.0.0;
  import host:interfaces/logging@2.1.0;
  import host:interfaces/kv-store@2.1.0;
  import host:interfaces/http@2.1.0;
  export contracts;
}

interface contracts {
  record generic-input {
    input:        option<list<u8>>,
    user-profile: option<list<u8>>,
    context:      option<list<u8>>,
  }
  forward: func(req: generic-input) -> result<list<u8>, string>;
  release-to-tenant: func(req: generic-input) -> result<list<u8>, string>;
}
