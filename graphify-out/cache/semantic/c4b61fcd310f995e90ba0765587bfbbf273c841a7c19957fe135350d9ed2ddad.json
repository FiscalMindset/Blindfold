{"nodes": [{"id": "forward_forward", "label": "forward() \u2014 in-enclave outbound call", "file_type": "code", "source_file": "contract/src/forward.rs", "source_location": "51", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "forward_release_to_tenant", "label": "release_to_tenant() \u2014 plaintext to authenticated tenant", "file_type": "code", "source_file": "contract/src/forward.rs", "source_location": "108", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "forward_read_secret", "label": "read_secret() \u2014 KV read from enclave", "file_type": "code", "source_file": "contract/src/forward.rs", "source_location": "119", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "forward_sentinel", "label": "SENTINEL constant (__BLINDFOLD__)", "file_type": "code", "source_file": "contract/src/forward.rs", "source_location": "11", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "forward_forwardinput", "label": "ForwardInput struct", "file_type": "code", "source_file": "contract/src/forward.rs", "source_location": "15", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "forward_forwardoutput", "label": "ForwardOutput struct", "file_type": "code", "source_file": "contract/src/forward.rs", "source_location": "38", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "forward_releaseinput", "label": "ReleaseInput struct", "file_type": "code", "source_file": "contract/src/forward.rs", "source_location": "105", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "forward_releaseoutput", "label": "ReleaseOutput struct", "file_type": "code", "source_file": "contract/src/forward.rs", "source_location": "106", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "sentinel_substitution_pattern", "label": "Sentinel substitution pattern \u2014 __BLINDFOLD__ replaced with real secret in-enclave", "file_type": "rationale", "source_file": "contract/src/forward.rs", "source_location": "58", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The sentinel value __BLINDFOLD__ acts as a placeholder in headers. It is substituted with the real secret only inside the TDX enclave, ensuring the plaintext never exists in the caller's process. This is the core security invariant of the entire Blindfold system."}, {"id": "enclave_egress_pattern", "label": "Enclave-egress pattern \u2014 outbound HTTPS from inside TDX", "file_type": "rationale", "source_file": "contract/src/forward.rs", "source_location": "79", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The contract makes the real outbound HTTP call from within the TDX enclave. The plaintext secret never leaves the enclave process \u2014 it exists only on the stack between read_secret() and http::call(). This eliminates the attack surface where a compromised agent could intercept the secret in transit."}, {"id": "release_broker_pattern", "label": "Release-broker pattern \u2014 plaintext returned to authenticated tenant only", "file_type": "rationale", "source_file": "contract/src/forward.rs", "source_location": "103", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "When in-enclave HTTP is not available or practical (e.g. SMTP), release_to_tenant returns the plaintext to the authenticated tenant over the T3-encrypted session. The local broker uses it once and drops it. This is the fallback path when enclave-egress cannot be used."}], "edges": [{"source": "forward_forward", "target": "forward_read_secret", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "contract/src/forward.rs", "source_location": "57", "weight": 1.0}, {"source": "forward_release_to_tenant", "target": "forward_read_secret", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "contract/src/forward.rs", "source_location": "111", "weight": 1.0}, {"source": "forward_forward", "target": "forward_sentinel", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "contract/src/forward.rs", "source_location": "59", "weight": 1.0}, {"source": "forward_forward", "target": "sentinel_substitution_pattern", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "contract/src/forward.rs", "source_location": "58", "weight": 1.0}, {"source": "forward_forward", "target": "enclave_egress_pattern", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "contract/src/forward.rs", "source_location": "81", "weight": 1.0}, {"source": "forward_release_to_tenant", "target": "release_broker_pattern", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "contract/src/forward.rs", "source_location": "108", "weight": 1.0}], "hyperedges": [{"id": "enclave_call_pipeline", "label": "Enclave call pipeline \u2014 seal \u2192 grant egress \u2192 contract forward \u2192 http::call", "nodes": ["forward_forward", "forward_read_secret", "egress_grant_mechanism", "sentinel_substitution_pattern", "enclave_egress_pattern"], "relation": "participate_in", "confidence": "EXTRACTED", "confidence_score": 0.95, "source_file": "contract/src/forward.rs"}]}