{
  "name": "@fiscalmindset/blindfold",
  "version": "0.3.0",
  "type": "module",
  "description": "Make any AI agent's API keys un-leakable, by sealing them inside a Terminal 3 TDX enclave.",
  "publishConfig": { "access": "public" },
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./proxy": "./src/proxy.ts",
    "./register": "./src/register.ts",
    "./wrap": "./src/wrap.ts"
  },
  "bin": {
    "blindfold": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "src",
    "assets",
    "postinstall.mjs",
    "README.md"
  ],
  "scripts": {
    "start": "tsx bin/blindfold.ts",
    "build": "esbuild bin/blindfold.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/cli.mjs --external:@terminal3/t3n-sdk && node copy-assets.mjs",
    "prepare": "npm run build",
    "postinstall": "node postinstall.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "optionalDependencies": {
    "@terminal3/t3n-sdk": "^3.12.3"
  }
}
