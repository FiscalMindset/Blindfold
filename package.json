{
  "name": "blindfold-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Blindfold — make any AI agent's API keys un-leakable by sealing them inside a Terminal 3 TDX enclave.",
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "hooks": "git config core.hooksPath .githooks",
    "prepare": "git config core.hooksPath .githooks || true",
    "secrets:scan": "gitleaks git --redact --no-banner --config .gitleaks.toml",
    "test:security": "tsx --test packages/blindfold/test/security.test.ts",
    "sync:skill": "bash scripts/sync-skill.sh",
    "build:contract": "bash scripts/build-contract.sh",
    "setup": "tsx packages/blindfold/bin/blindfold.ts init",
    "blindfold": "tsx packages/blindfold/bin/blindfold.ts",
    "demo": "tsx demo/run-demo.ts",
    "demo:a": "tsx demo/agent-a-leaks/index.ts",
    "demo:b": "tsx demo/agent-b-blindfolded/index.ts",
    "dashboard": "tsx packages/blindfold/bin/blindfold.ts dashboard",
    "test:report": "tsx scripts/run-tests.ts",
    "test:providers": "tsx scripts/test-providers.ts",
    "test:real": "tsx scripts/real-e2e-test.ts",
    "demo:smtp": "tsx scripts/demo-smtp.ts",
    "compat": "tsx packages/blindfold/bin/blindfold.ts compat",
    "env:fingerprint": "bash scripts/env-fingerprint.sh",
    "seal:blogger": "tsx scripts/seal-blogger-key.ts",
    "chatbot": "tsx packages/chatbot/bin/chatbot.ts",
    "chatbot:serve": "tsx packages/chatbot/bin/chatbot.ts serve",
    "chatbot:extract": "tsx packages/chatbot/bin/extract-knowledge.ts",
    "chatbot:audit": "tsx packages/chatbot/bin/chatbot.ts audit"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@terminal3/t3n-sdk": "^3.12.3",
    "@types/nodemailer": "^8.0.1",
    "nodemailer": "^9.0.1",
    "openai": "^6.44.0"
  }
}
